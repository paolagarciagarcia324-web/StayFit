Project stayfit {
  database_type: "MySQL / MariaDB"
  Note: "Modelo editable de StayFit con flujo de plan, pago, solicitud de compra, validacion administrativa, cliente activo y acceso por modulos."
}

// =========================================================
// Seguridad, usuarios y roles
// =========================================================
Table user {
  id_user int [pk, increment, note: "Identificador unico del usuario."]
  nombres varchar(100) [note: "Nombres del usuario."]
  apellidos varchar(100) [note: "Apellidos del usuario."]
  documento_identidad varchar(30) [unique, note: "Documento de identidad."]
  correo varchar(150) [unique, note: "Correo de acceso."]
  telefono varchar(30) [note: "Telefono de contacto."]
  password_hash varchar(255) [note: "Contrasena cifrada."]
  foto_perfil_url varchar(255) [note: "Ruta de foto de perfil."]
  estado varchar [note: "ACTIVO, INACTIVO, BLOQUEADO o PENDIENTE."]
  correo_verificado_en datetime [note: "Fecha de verificacion de correo."]
  ultimo_acceso_en datetime [note: "Ultimo ingreso."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table roles {
  id_rol int [pk, increment, note: "Identificador del rol."]
  codigo varchar(50) [unique, note: "Codigo interno: ADMIN, COACH, CLIENTE, CLIENTE_INSTITUCIONAL."]
  nombre varchar(80) [note: "Nombre visible del rol."]
  descripcion varchar(255) [note: "Descripcion."]
  estado varchar [note: "Estado del rol."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table user_roles {
  id_user_rol int [pk, increment, note: "Identificador."]
  id_user int [note: "Usuario asociado."]
  id_rol int [note: "Rol asociado."]
  creado_en timestamp [note: "Fecha de asignacion."]
}

Table tokens_recuperacion {
  id_token int [pk, increment, note: "Identificador."]
  id_user int [note: "Usuario solicitante."]
  token varchar(255) [unique, note: "Token de recuperacion."]
  usado tinyint(1) [note: "Indica si fue utilizado."]
  expira_en datetime [note: "Fecha de expiracion."]
  creado_en timestamp [note: "Fecha de creacion."]
}

// =========================================================
// Clientes, coaches e instituciones
// =========================================================
Table clientes {
  id_cliente int [pk, increment, note: "Identificador."]
  id_user int [unique, note: "Usuario asociado."]
  id_coach int [note: "Coach asignado."]
  id_institucion int [note: "Institucion asociada."]
  fecha_nacimiento date [note: "Nacimiento."]
  genero varchar [note: "Genero."]
  direccion varchar(180) [note: "Direccion."]
  ciudad varchar(100) [note: "Ciudad."]
  objetivo_principal varchar(180) [note: "Objetivo fitness."]
  peso_inicial_kg decimal(5,2) [note: "Peso inicial."]
  estatura_cm decimal(5,2) [note: "Estatura."]
  estado_cliente varchar [note: "ACTIVA, INACTIVA o SUSPENDIDA."]
  fecha_alta date [note: "Fecha de activacion como cliente."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table coaches {
  id_coach int [pk, increment, note: "Identificador."]
  id_user int [unique, note: "Usuario asociado."]
  especialidad varchar(120) [note: "Especialidad."]
  experiencia_anios int [note: "Experiencia."]
  certificaciones text [note: "Certificaciones."]
  biografia text [note: "Biografia."]
  estado_coach varchar [note: "ACTIVO o INACTIVO."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table instituciones {
  id_institucion int [pk, increment, note: "Identificador."]
  nombre varchar(150) [note: "Nombre de institucion."]
  nit varchar(50) [unique, note: "NIT o identificacion."]
  tipo_institucion varchar(80) [note: "Tipo."]
  nombre_contacto varchar(120) [note: "Contacto principal."]
  correo_contacto varchar(150) [note: "Correo."]
  telefono_contacto varchar(30) [note: "Telefono."]
  direccion varchar(180) [note: "Direccion."]
  ciudad varchar(100) [note: "Ciudad."]
  observaciones text [note: "Notas."]
  estado varchar [note: "ACTIVA o INACTIVA."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

// =========================================================
// Planes, compra, cupos, pagos y acceso
// =========================================================
Table planes {
  id_plan int [pk, increment, note: "Identificador."]
  nombre varchar(150) [note: "Nombre del plan."]
  slug varchar(170) [unique, note: "Identificador URL."]
  descripcion text [note: "Descripcion."]
  precio decimal(12,2) [note: "Precio."]
  duracion_dias int [note: "Duracion."]
  modalidad varchar [note: "VIRTUAL, PRESENCIAL o MIXTO."]
  tipo_cliente varchar [note: "INDIVIDUAL, INSTITUCIONAL o AMBOS."]
  cupo_maximo int [note: "Cupo maximo; NULL = sin limite."]
  requiere_coach tinyint(1) [note: "Requiere coach."]
  incluye_entrenamiento tinyint(1) [note: "Incluye modulo entrenamiento."]
  incluye_nutricion tinyint(1) [note: "Incluye modulo nutricion."]
  incluye_videos tinyint(1) [note: "Incluye videos."]
  incluye_sesiones tinyint(1) [note: "Incluye sesiones."]
  incluye_eventos tinyint(1) [note: "Incluye eventos."]
  imagen_url varchar(255) [note: "Imagen."]
  destacado tinyint(1) [note: "Plan destacado."]
  fecha_inicio_programa date [note: "Inicio del programa."]
  fecha_fin_programa date [note: "Fin del programa."]
  estado_plan varchar [note: "ACTIVO o INACTIVO."]
  creado_por int [note: "Usuario creador."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table modulos_servicio {
  id_modulo int [pk, increment, note: "Identificador."]
  codigo varchar(50) [unique, note: "Codigo del modulo."]
  nombre varchar(100) [note: "Nombre."]
  descripcion varchar(255) [note: "Descripcion."]
  estado varchar [note: "Estado."]
  creado_en timestamp [note: "Creacion."]
}

Table plan_modulos {
  id_plan_modulo int [pk, increment, note: "Identificador."]
  id_plan int [note: "Plan."]
  id_modulo int [note: "Modulo."]
  creado_en timestamp [note: "Creacion."]
}

Table solicitudes_compra {
  id_solicitud int [pk, increment, note: "Identificador."]
  codigo_solicitud varchar(40) [unique, note: "Codigo de trazabilidad."]
  id_plan int [note: "Plan comprado."]
  id_institucion int [note: "Institucion si aplica."]
  nombres varchar(100) [note: "Nombres comprador."]
  apellidos varchar(100) [note: "Apellidos comprador."]
  documento_identidad varchar(30) [note: "Documento."]
  correo varchar(150) [note: "Correo."]
  telefono varchar(30) [note: "Telefono."]
  ciudad varchar(100) [note: "Ciudad."]
  tipo_cliente varchar [note: "Tipo comprador."]
  observacion_usuario text [note: "Observacion."]
  estado_solicitud varchar [note: "PENDIENTE, VALIDADA, RECHAZADA, CANCELADA."]
  revisado_por int [note: "Administrador revisor."]
  fecha_revision datetime [note: "Fecha revision."]
  observacion_admin text [note: "Observacion de revision."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table pagos {
  id_pago int [pk, increment, note: "Identificador."]
  id_solicitud int [unique, note: "Solicitud relacionada."]
  id_cliente int [note: "Cliente cuando ya exista."]
  id_plan int [note: "Plan pagado."]
  monto decimal(12,2) [note: "Monto."]
  metodo_pago varchar [note: "Metodo usado."]
  referencia_pago varchar(120) [note: "Referencia."]
  comprobante_url varchar(255) [note: "Comprobante."]
  estado_pago varchar [note: "PENDIENTE, VALIDADO, RECHAZADO."]
  fecha_pago datetime [note: "Fecha pago."]
  validado_por int [note: "Administrador validador."]
  fecha_validacion datetime [note: "Fecha validacion."]
  observacion_admin text [note: "Observacion."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table planes_cliente {
  id_plan_cliente int [pk, increment, note: "Identificador."]
  id_cliente int [note: "Cliente."]
  id_plan int [note: "Plan."]
  id_solicitud int [note: "Solicitud origen."]
  id_pago int [note: "Pago origen."]
  fecha_inicio date [note: "Inicio vigencia."]
  fecha_fin date [note: "Fin vigencia."]
  estado_plan_cliente varchar [note: "ACTIVO, VENCIDO, CANCELADO, SUSPENDIDO."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table acceso_cliente_modulo {
  id_acceso int [pk, increment, note: "Identificador."]
  id_plan_cliente int [note: "Plan del cliente."]
  id_cliente int [note: "Cliente."]
  id_modulo int [note: "Modulo."]
  fecha_inicio date [note: "Inicio."]
  fecha_fin date [note: "Fin."]
  estado_acceso varchar [note: "ACTIVO, INACTIVO, VENCIDO."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

// =========================================================
// Programas virtuales y videos
// =========================================================
Table programas_virtuales {
  id_programa int [pk, increment, note: "Identificador."]
  id_plan int [note: "Plan asociado."]
  nombre varchar(150) [note: "Nombre."]
  descripcion text [note: "Descripcion."]
  imagen_url varchar(255) [note: "Imagen."]
  estado_programa varchar [note: "Estado."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table categorias_video {
  id_categoria int [pk, increment, note: "Identificador."]
  nombre varchar(120) [note: "Nombre."]
  descripcion varchar(255) [note: "Descripcion."]
  orden int [note: "Orden."]
  estado_categoria varchar [note: "Estado."]
  creado_en timestamp [note: "Creacion."]
}

Table videos {
  id_video int [pk, increment, note: "Identificador."]
  id_programa int [note: "Programa."]
  id_categoria int [note: "Categoria."]
  titulo varchar(160) [note: "Titulo."]
  descripcion text [note: "Descripcion."]
  url_video varchar(255) [note: "Enlace video."]
  imagen_portada_url varchar(255) [note: "Portada."]
  duracion_minutos int [note: "Duracion."]
  orden int [note: "Orden."]
  estado_video varchar [note: "Estado."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table progreso_videos {
  id_progreso_video int [pk, increment, note: "Identificador."]
  id_cliente int [note: "Cliente."]
  id_video int [note: "Video."]
  estado_progreso varchar [note: "NO_INICIADO, EN_PROGRESO, COMPLETADO."]
  porcentaje_avance decimal(5,2) [note: "Porcentaje."]
  iniciado_en datetime [note: "Inicio."]
  completado_en datetime [note: "Fin."]
  actualizado_en timestamp [note: "Actualizacion."]
}

// =========================================================
// Entrenamiento
// =========================================================
Table planes_entrenamiento {
  id_plan_entrenamiento int [pk, increment, note: "Identificador."]
  id_cliente int [note: "Cliente."]
  id_plan int [note: "Plan comercial."]
  id_coach int [note: "Coach."]
  titulo varchar(150) [note: "Titulo."]
  objetivo text [note: "Objetivo."]
  nivel varchar [note: "Nivel."]
  fecha_inicio date [note: "Inicio."]
  fecha_fin date [note: "Fin."]
  estado_entrenamiento varchar [note: "Estado."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table rutinas {
  id_rutina int [pk, increment, note: "Identificador."]
  id_plan_entrenamiento int [note: "Plan entrenamiento."]
  titulo varchar(150) [note: "Titulo."]
  descripcion text [note: "Descripcion."]
  dia_semana varchar [note: "Dia sugerido."]
  orden int [note: "Orden."]
  estado_rutina varchar [note: "Estado."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table ejercicios {
  id_ejercicio int [pk, increment, note: "Identificador."]
  nombre varchar(150) [note: "Nombre."]
  descripcion text [note: "Descripcion."]
  grupo_muscular varchar(120) [note: "Grupo muscular."]
  equipo_necesario varchar(150) [note: "Equipo."]
  url_video varchar(255) [note: "Video."]
  imagen_url varchar(255) [note: "Imagen."]
  estado_ejercicio varchar [note: "Estado."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table rutina_ejercicios {
  id_rutina_ejercicio int [pk, increment, note: "Identificador."]
  id_rutina int [note: "Rutina."]
  id_ejercicio int [note: "Ejercicio."]
  series int [note: "Series."]
  repeticiones varchar(50) [note: "Repeticiones."]
  duracion_segundos int [note: "Duracion."]
  descanso_segundos int [note: "Descanso."]
  orden int [note: "Orden."]
  observaciones text [note: "Observaciones."]
}

Table material_entrenamiento {
  id_material int [pk, increment, note: "Identificador."]
  id_plan_entrenamiento int [note: "Plan entrenamiento."]
  titulo varchar(150) [note: "Titulo."]
  tipo_material varchar [note: "PDF, VIDEO, IMAGEN, ENLACE, OTRO."]
  url_material varchar(255) [note: "Ruta o enlace."]
  descripcion text [note: "Descripcion."]
  creado_en timestamp [note: "Creacion."]
}

Table registro_rutinas {
  id_registro_rutina int [pk, increment, note: "Identificador."]
  id_cliente int [note: "Cliente."]
  id_rutina int [note: "Rutina."]
  fecha_registro date [note: "Fecha."]
  estado_registro varchar [note: "PENDIENTE, COMPLETADA, NO_REALIZADA."]
  observaciones text [note: "Observaciones."]
  creado_en timestamp [note: "Creacion."]
}

// =========================================================
// Nutricion
// =========================================================
Table planes_nutricionales {
  id_plan_nutricional int [pk, increment, note: "Identificador."]
  id_cliente int [note: "Cliente."]
  id_coach int [note: "Coach."]
  titulo varchar(150) [note: "Titulo."]
  objetivo text [note: "Objetivo."]
  calorias_diarias int [note: "Calorias."]
  recomendaciones_generales text [note: "Recomendaciones."]
  fecha_inicio date [note: "Inicio."]
  fecha_fin date [note: "Fin."]
  estado_nutricional varchar [note: "Estado."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table comidas {
  id_comida int [pk, increment, note: "Identificador."]
  id_plan_nutricional int [note: "Plan nutricional."]
  tipo_comida varchar [note: "Tipo."]
  nombre varchar(150) [note: "Nombre."]
  descripcion text [note: "Descripcion."]
  hora_sugerida time [note: "Hora sugerida."]
  calorias_aprox int [note: "Calorias."]
  orden int [note: "Orden."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

// =========================================================
// Progreso fisico
// =========================================================
Table registros_progreso {
  id_registro_progreso int [pk, increment, note: "Identificador."]
  id_cliente int [note: "Cliente."]
  registrado_por int [note: "Usuario que registra."]
  fecha_registro date [note: "Fecha."]
  peso_kg decimal(5,2) [note: "Peso."]
  cintura_cm decimal(5,2) [note: "Cintura."]
  cadera_cm decimal(5,2) [note: "Cadera."]
  pecho_cm decimal(5,2) [note: "Pecho."]
  brazo_cm decimal(5,2) [note: "Brazo."]
  pierna_cm decimal(5,2) [note: "Pierna."]
  foto_url varchar(255) [note: "Foto."]
  observaciones_cliente text [note: "Observaciones cliente."]
  observaciones_coach text [note: "Observaciones coach."]
  creado_en timestamp [note: "Creacion."]
}

// =========================================================
// Agenda, sesiones y eventos
// =========================================================
Table sesiones {
  id_sesion int [pk, increment, note: "Identificador."]
  id_coach int [note: "Coach."]
  id_cliente int [note: "Cliente."]
  id_institucion int [note: "Institucion."]
  id_plan int [note: "Plan."]
  titulo varchar(160) [note: "Titulo."]
  descripcion text [note: "Descripcion."]
  tipo_sesion varchar [note: "Tipo."]
  modalidad varchar [note: "Modalidad."]
  fecha_inicio datetime [note: "Inicio."]
  fecha_fin datetime [note: "Fin."]
  ubicacion varchar(180) [note: "Ubicacion."]
  enlace_virtual varchar(255) [note: "Enlace."]
  cupo_maximo int [note: "Cupo."]
  estado_sesion varchar [note: "Estado."]
  creado_por int [note: "Usuario creador."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table sesion_participantes {
  id_sesion_participante int [pk, increment, note: "Identificador."]
  id_sesion int [note: "Sesion."]
  id_cliente int [note: "Cliente."]
  estado_asistencia varchar [note: "Estado asistencia."]
  observaciones text [note: "Observaciones."]
  creado_en timestamp [note: "Creacion."]
}

Table eventos {
  id_evento int [pk, increment, note: "Identificador."]
  id_institucion int [note: "Institucion."]
  titulo varchar(160) [note: "Titulo."]
  descripcion text [note: "Descripcion."]
  modalidad varchar [note: "Modalidad."]
  fecha_inicio datetime [note: "Inicio."]
  fecha_fin datetime [note: "Fin."]
  ubicacion varchar(180) [note: "Ubicacion."]
  enlace_virtual varchar(255) [note: "Enlace."]
  cupo_maximo int [note: "Cupo."]
  precio decimal(12,2) [note: "Precio."]
  imagen_url varchar(255) [note: "Imagen."]
  estado_evento varchar [note: "Estado."]
  creado_por int [note: "Usuario creador."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table evento_participantes {
  id_evento_participante int [pk, increment, note: "Identificador."]
  id_evento int [note: "Evento."]
  id_cliente int [note: "Cliente."]
  nombre_invitado varchar(150) [note: "Invitado."]
  correo_invitado varchar(150) [note: "Correo invitado."]
  telefono_invitado varchar(30) [note: "Telefono."]
  estado_participacion varchar [note: "Estado."]
  creado_en timestamp [note: "Creacion."]
}

// =========================================================
// Comunicacion
// =========================================================
Table chats {
  id_chat int [pk, increment, note: "Identificador."]
  tipo_chat varchar [note: "Tipo."]
  id_cliente int [note: "Cliente."]
  id_coach int [note: "Coach."]
  id_institucion int [note: "Institucion."]
  asunto varchar(160) [note: "Asunto."]
  estado_chat varchar [note: "Estado."]
  creado_en timestamp [note: "Creacion."]
  actualizado_en timestamp [note: "Actualizacion."]
}

Table mensajes {
  id_mensaje int [pk, increment, note: "Identificador."]
  id_chat int [note: "Chat."]
  id_user_emisor int [note: "Usuario emisor."]
  mensaje text [note: "Texto."]
  archivo_url varchar(255) [note: "Adjunto."]
  leido tinyint(1) [note: "Leido."]
  fecha_lectura datetime [note: "Fecha lectura."]
  creado_en timestamp [note: "Creacion."]
}

Table notificaciones {
  id_notificacion int [pk, increment, note: "Identificador."]
  id_user int [note: "Destinatario."]
  titulo varchar(160) [note: "Titulo."]
  mensaje text [note: "Mensaje."]
  tipo_notificacion varchar [note: "Tipo."]
  url_destino varchar(255) [note: "Enlace destino."]
  leida tinyint(1) [note: "Leida."]
  fecha_lectura datetime [note: "Fecha lectura."]
  creado_en timestamp [note: "Creacion."]
}

// =========================================================
// Reportes y trazabilidad
// =========================================================
Table reportes_generados {
  id_reporte int [pk, increment, note: "Identificador."]
  id_user int [note: "Usuario generador."]
  tipo_reporte varchar [note: "Tipo."]
  nombre_reporte varchar(160) [note: "Nombre."]
  parametros_json json [note: "Parametros."]
  archivo_url varchar(255) [note: "Archivo."]
  generado_en timestamp [note: "Fecha generacion."]
}

Table bitacora_sistema {
  id_bitacora int [pk, increment, note: "Identificador."]
  id_user int [note: "Usuario responsable."]
  modulo varchar(80) [note: "Modulo."]
  accion varchar(120) [note: "Accion."]
  descripcion text [note: "Detalle."]
  ip varchar(45) [note: "Direccion IP."]
  user_agent varchar(255) [note: "Agente navegador."]
  creado_en timestamp [note: "Creacion."]
}

// Relaciones principales
Ref: user_roles.id_user > user.id_user // Un usuario puede tener uno o varios roles.
Ref: user_roles.id_rol > roles.id_rol // Un rol puede asignarse a muchos usuarios.
Ref: tokens_recuperacion.id_user > user.id_user // Un usuario puede solicitar tokens de recuperacion.
Ref: coaches.id_user > user.id_user // Cada coach pertenece a un usuario.
Ref: clientes.id_user > user.id_user // Cada cliente pertenece a un usuario.
Ref: clientes.id_coach > coaches.id_coach // Un coach puede tener varios clientes.
Ref: clientes.id_institucion > instituciones.id_institucion // Una institucion puede vincular varios clientes.
Ref: planes.creado_por > user.id_user // Usuario administrador que crea el plan.
Ref: plan_modulos.id_plan > planes.id_plan // Un plan puede incluir varios modulos.
Ref: plan_modulos.id_modulo > modulos_servicio.id_modulo // Un modulo puede estar en varios planes.
Ref: solicitudes_compra.id_plan > planes.id_plan // Cada solicitud corresponde a un plan.
Ref: solicitudes_compra.id_institucion > instituciones.id_institucion // Solicitud institucional opcional.
Ref: solicitudes_compra.revisado_por > user.id_user // Administrador que valida o rechaza.
